# Clerk auth + billing (Liquid Clips production)
# Copy to .env.local for local dev. Set on Vercel for production.

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Clerk billing plan IDs — defaults are pinned in PricingCards.tsx, but
# overriding here lets Vercel swap to test-mode plans without a redeploy.
# Confirm the IDs match the live plans in https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_SOLO_PLAN_ID=cplan_3E4VBeiWtZP0CJsvPwrIz91uDFk
NEXT_PUBLIC_CLERK_PRO_PLAN_ID=cplan_3EV9Jjn8qLG130iSSRpAUOmqAfm
NEXT_PUBLIC_CLERK_AGENCY_PLAN_ID=cplan_3E4VBfKWkQlIuYRQG0YE5LfJPjx
NEXT_PUBLIC_CLERK_ACCOUNT_PACK_PLAN_ID=cplan_3EV9znSsguzmwoQoEr5kXpumkfM

# Junior Backend (license issuance + tier resolution)
NEXT_PUBLIC_JUNIOR_BACKEND_URL=https://api.jnremployee.com

# Optional: PostHog (signup funnel telemetry)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
